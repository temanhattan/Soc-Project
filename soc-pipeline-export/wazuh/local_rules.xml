<!-- Example -->
<group name="local,syslog,sshd,">

  <!--
  Dec 10 01:02:02 host sshd[1234]: Failed none for root from 1.1.1.1 port 1066 ssh2
  -->
  <rule id="100001" level="5">
    <if_sid>5716</if_sid>
    <srcip>1.1.1.1</srcip>
    <description>sshd: authentication failed from IP 1.1.1.1.</description>
    <group>authentication_failed,pci_dss_10.2.4,pci_dss_10.2.5,</group>
  </rule>

</group>

<group name="custom_sysmon_alerts">
  
  <rule id="100005" level="12">
    <if_group>sysmon_event1</if_group>
    <match>whoami.exe</match>
    <description>Custom Alert: 'whoami' Discovery Command Executed by attacker.</description>
    <mitre>
      <id>T1033</id>
    </mitre>
  </rule>

  <rule id="100010" level="12">
    <if_sid>61614</if_sid>
    <field name="win.eventdata.targetImage">\.?lsass\.exe</field>
    <description>SOC Alert: Suspicious Process Access to LSASS (Possible Credential Dumping)</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
  </rule>
  
  <rule id="100011" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine">(?i)comsvcs\.dll.*MiniDump</field>
    <description>SOC Alert: Suspicious Command Line (Attempted LSASS Dump via comsvcs.dll)</description>
    <mitre>
      <id>T1003.001</id>
    </mitre>
  </rule>
  
  <rule id="100015" level="12">
    <if_group>sysmon_event1</if_group>
    <field name="win.eventdata.commandLine">(?i)reg.*save.*sam</field>
    <description>SOC Alert: Suspicious Registry Save (Possible SAM Credential Dump)</description>
    <mitre>
      <id>T1003.002</id>
    </mitre>
  </rule> 
  
  <rule id="100016" level="12">
    <if_sid>92031</if_sid> 
    <field name="win.eventdata.commandLine" type="pcre2">(?i)net(\d)?\.exe"?\s+(user|localgroup)\b</field>
    <description>SOC Alert: Malicious Local Account Discovery (Atomic Red Team T1087.001)</description>
    <mitre>
      <id>T1087.001</id>
    </mitre>
  </rule>
</group>